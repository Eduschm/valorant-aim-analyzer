# Copy this to .env and fill in values. Never commit .env.

# ---- Riot Games API ----
# Apply at: https://developer.riotgames.com/app-type
# Dev key expires every 24h. Apply for production key early (takes a few days).
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---- Henrik Dev API (optional, raises Riot rate limits) ----
# Sign up at: https://docs.henrikdev.xyz/
HENRIK_API_KEY=

# ---- Anthropic API ----
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ---- LLM model ----
# Production: claude-haiku-4-5
# Dev/testing: claude-haiku-4-5 (cheapest), or local
LLM_MODEL=claude-haiku-4-5

# ---- Database (Neon or Supabase free tier) ----
# Format: postgresql+asyncpg://user:password@host/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost/valorant_aim

# ---- Redis (for job queue) ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
JWT_EXPIRE_MINUTES=10080

# ---- Email (Resend) ----
# Sign up at: https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ---- Storage (Cloudflare R2 or AWS S3) ----
S3_BUCKET=valorant-clips
S3_ACCESS_KEY=xxxxxxxxxxxx
S3_SECRET_KEY=xxxxxxxxxxxx
S3_ENDPOINT_URL=https://xxxxxxxxxxxx.r2.cloudflarestorage.com

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MOCK_MODE=true
