# Environment Variables — Copy to .env and fill in values

# ============================================================================
# Riot API (Required)
# ============================================================================
# Get from: https://developer.riotgames.com/
# Dev keys expire every 24h; production keys are stable
# NOTE: dev/personal keys 403 on val/match/v1 (match data). Used as a fallback
# match provider only — set HENRIK_API_KEY below for the working match path.
RIOT_API_KEY=RGAPI-xxxxx

# ============================================================================
# HenrikDev API (match-data provider)
# ============================================================================
# Free key from the HenrikDev Discord: https://discord.com/invite/X3GaVkX2YN
#   -> verify -> #get-a-key -> "VALORANT (Basic Key)"
# When set, the pipeline uses Henrik for match history + MMR (no production
# Riot key needed). Leave empty to fall back to the Riot match endpoint.
HENRIK_API_KEY=HDEV-xxxxx
# Force a provider regardless of keys: "henrik" | "riot" (default: auto)
# MATCH_PROVIDER=henrik

# ============================================================================
# Anthropic API (Required for LLM coaching)
# ============================================================================
# Get from: https://console.anthropic.com/
# Free tier: 100k input + 25k output tokens/month
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ============================================================================
# Development
# ============================================================================
# Enable dev-only API endpoints (/auth/dev/*)
DEV_MODE=false

# ============================================================================
# Logging
# ============================================================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Resend Email (Phase 1B: Magic links)
# ============================================================================
# Get from: https://resend.com/ (100 emails/day free)
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=noreply@valorant-analyzer.io

# ============================================================================
# Database (Phase 1B: User accounts)
# ============================================================================
# PostgreSQL connection string
# Get free database at: https://neon.tech/ or https://supabase.com/
# DATABASE_URL=postgresql://user:password@host/dbname

# ============================================================================
# JWT Secrets (Phase 1B: Auth)
# ============================================================================
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# JWT_SECRET=xxxxx

# ============================================================================
# Frontend (Next.js)
# ============================================================================
# API backend URL (empty = localhost:8000)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Use mock data instead of calling API (useful for frontend dev)
# NEXT_PUBLIC_MOCK_MODE=false

# Frontend logger level: debug, info, warn, error
# NEXT_PUBLIC_LOG_LEVEL=debug
