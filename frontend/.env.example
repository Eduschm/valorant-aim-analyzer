# Copy to .env.local and fill in values. Never commit .env.local.

# FastAPI backend URL (runs on port 8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to true to use mock data (no backend needed)
# Set to false once the API is running with real keys
NEXT_PUBLIC_MOCK_MODE=true

# Internal server-side URL for Next.js API routes → FastAPI proxying
# Same as NEXT_PUBLIC_API_URL in local dev
API_URL=http://localhost:8000
